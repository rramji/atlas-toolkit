BIOGRF 200
REMARK selected atoms according to index>0
REMARK Cl-Chlorine.bgf modified FFTYPE:Cl
DESCRP __tmp.pdb
FORCEFIELD DREIDING  
PERIOD 111
AXES   ZYX
SGNAME P 1                  1    1
CRYSTX     5.24000     5.26000     5.48000    90.00000    90.00000    90.00000
CELLS    -1    1   -1    1   -1    1
FORMAT ATOM   (a6,1x,i5,1x,a5,1x,a3,1x,a1,1x,a5,3f10.5,1x,a5,i3,i2,1x,f8.5,f10.5)
HETATM     1 CL1   RES A   444   0.00000   0.82600   0.58200 Cl-    1 0 -1.00000
FORMAT CONECT (a6,12i6)
CONECT     1    
END
